{
  "$schema": "dil-domain-registry-v1",
  "description": "Canonical domain registry for DIL operational path resolution",
  "updated": "2026-03-12",
  "domains": {
    "personal": {
      "name": "Personal",
      "display_order": 2,
      "briefing_label": "Personal",
      "task_dir": "_shared/domains/personal/tasks",
      "log_dir": "_shared/domains/personal/logs",
      "data_dir": "_shared/domains/personal/data",
      "id_prefix": "DIL",
      "id_mode": "auto",
      "default_owner": "moo",
      "path_type": "relative",
      "log_prune": {
        "strategy": "trailing_window",
        "window_days": 180
      },
      "archive": {
        "after_days": 180,
        "year_key": "terminal_date",
        "strategy": "active_archived"
      },
      "status": "active"
    },
    "work": {
      "name": "AutoZone",
      "display_order": 1,
      "briefing_label": "Work \u2014 AutoZone",
      "task_dir": "_shared/domains/work/tasks",
      "log_dir": "/az/talend/logs",
      "data_dir": "/az/talend/data",
      "id_prefix": "DMDI",
      "id_mode": "external",
      "default_owner": "charlie",
      "path_type": "mixed",
      "log_prune": {
        "strategy": "trailing_window",
        "window_days": 90
      },
      "archive": {
        "after_days": 90,
        "year_key": "terminal_date",
        "strategy": "active_archived"
      },
      "status": "active"
    },
    "triv": {
      "name": "Three Rivers Duck Club",
      "display_order": 3,
      "briefing_label": "Triv \u2014 Three Rivers Duck Club",
      "task_dir": "_shared/domains/triv/tasks",
      "log_dir": "_shared/domains/triv/logs",
      "data_dir": "_shared/domains/triv/data",
      "id_prefix": "TRIV",
      "id_mode": "auto",
      "default_owner": "moo",
      "path_type": "relative",
      "log_prune": {
        "strategy": "trailing_window",
        "window_days": 365
      },
      "archive": {
        "after_days": 365,
        "year_key": "terminal_date",
        "strategy": "active_archived"
      },
      "status": "active"
    }
  },
  "prune_strategy_definitions": {
    "trailing_window": "Find the most recent log file in the domain log tree. Delete files older than window_days before that file."
  },
  "archive_strategy_definitions": {
    "active_archived": "Non-terminal tasks in active/. Terminal tasks (done/cancelled/retired) older than after_days move to archived/{year}/ based on year_key."
  },
  "path_resolution": {
    "description": "relative paths resolve against $BASE_DIL. absolute paths used as-is. mixed means task_dir is relative but log_dir/data_dir may be absolute.",
    "base_var": "BASE_DIL",
    "default_base": "/home/moo/Documents/dil_agentic_memory_0001"
  }
}
