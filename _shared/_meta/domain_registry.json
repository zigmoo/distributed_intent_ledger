{
  "$schema": "dil-domain-registry-v1",
  "description": "Canonical domain registry for DIL operational path resolution",
  "updated": "2026-03-12",
  "domains": {
    "personal": {
      "name": "Personal",
      "display_order": 2,
      "briefing_label": "Personal",
      "task_dir": "_shared/domains/personal/tasks",
      "log_dir": "_shared/domains/personal/logs",
      "data_dir": "_shared/domains/personal/data",
      "id_prefix": "DIL",
      "id_mode": "auto",
      "default_owner": "moo",
      "path_type": "relative",
      "ticket_systems": [],
      "links": [
        {"name": "DIL on GitHub", "url": "https://github.com/zigmoo/distributed_intent_ledger", "type": "repo"},
        {"name": "Getting Real (37signals)", "url": "https://basecamp.com/gettingreal", "type": "reference"},
        {"name": "Shape Up (37signals)", "url": "https://basecamp.com/shapeup", "type": "reference"},
        {"name": "1999.37signals.com", "url": "https://1999.37signals.com/", "type": "reference"}
      ],
      "log_prune": {
        "strategy": "trailing_window",
        "window_days": 180
      },
      "archive": {
        "after_days": 180,
        "year_key": "terminal_date",
        "strategy": "active_archived"
      },
      "status": "active"
    },
    "work": {
      "name": "Example Corp",
      "display_order": 1,
      "briefing_label": "Work \u2014 Example Corp",
      "task_dir": "_shared/domains/work/tasks",
      "log_dir": "/path/to/org/logs",
      "data_dir": "/path/to/org/data",
      "id_prefix": "PROJ",
      "id_mode": "external",
      "default_owner": "user",
      "path_type": "mixed",
      "ticket_systems": [
        {
          "name": "Jira",
          "type": "jira",
          "base_url": "https://jira.example.com",
          "browse_url_template": "https://jira.example.com/browse/{ticket_id}",
          "prefixes": ["PROJ"]
        },
        {
          "name": "GitLab",
          "type": "gitlab",
          "base_url": "https://gitlab.com",
          "browse_url_template": "https://gitlab.com/org/{path}",
          "group_path": "org",
          "prefixes": []
        }
      ],
      "links": [
        {"name": "Internal App", "url": "https://app.example.com/", "type": "app"},
        {"name": "Documentation", "url": "https://docs.example.com/", "type": "docs"},
        {"name": "Source repo", "url": "https://gitlab.com/org/project", "type": "repo"}
      ],
      "log_prune": {
        "strategy": "trailing_window",
        "window_days": 90
      },
      "archive": {
        "after_days": 90,
        "year_key": "terminal_date",
        "strategy": "active_archived"
      },
      "status": "active"
    },
    "triv": {
      "name": "Three Rivers Duck Club",
      "display_order": 3,
      "briefing_label": "Triv \u2014 Three Rivers Duck Club",
      "task_dir": "_shared/domains/triv/tasks",
      "log_dir": "_shared/domains/triv/logs",
      "data_dir": "_shared/domains/triv/data",
      "id_prefix": "TRIV",
      "id_mode": "auto",
      "default_owner": "moo",
      "path_type": "relative",
      "ticket_systems": [],
      "links": [],
      "log_prune": {
        "strategy": "trailing_window",
        "window_days": 365
      },
      "archive": {
        "after_days": 365,
        "year_key": "terminal_date",
        "strategy": "active_archived"
      },
      "status": "active"
    }
  },
  "prune_strategy_definitions": {
    "trailing_window": "Find the most recent log file in the domain log tree. Delete files older than window_days before that file."
  },
  "archive_strategy_definitions": {
    "active_archived": "Non-terminal tasks in active/. Terminal tasks (done/cancelled/retired) older than after_days move to archived/{year}/ based on year_key."
  },
  "path_resolution": {
    "description": "relative paths resolve against $BASE_DIL. absolute paths used as-is. mixed means task_dir is relative but log_dir/data_dir may be absolute.",
    "base_var": "BASE_DIL",
    "default_base": "/home/moo/Documents/dil_agentic_memory_0001"
  }
}
