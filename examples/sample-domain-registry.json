        {"name": "Shape Up (37signals)", "url": "https://basecamp.com/shapeup", "type": "reference"},
        {"name": "1999.37signals.com", "url": "https://1999.37signals.com/", "type": "reference"}
      ],
      "log_prune": {
        "strategy": "trailing_window",
        "window_days": 180
      },
      "archive": {
        "after_days": 180,
        "year_key": "terminal_date",
        "strategy": "active_archived"
      },
      "status": "active"
    },
    "work-clickup": {
      "name": "Acme Corp (ClickUp)",
      "display_order": 1,
      "briefing_label": "Work — Acme Corp",
      "task_dir": "_shared/domains/work-clickup/tasks",
      "log_dir": "/path/to/org/logs",
      "data_dir": "/path/to/org/data",
      "id_prefix": "ACM",
      "id_mode": "external",
      "default_owner": "user",
      "path_type": "mixed",
      "ticket_systems": [
        {
          "name": "ClickUp",
          "type": "clickup",
          "base_url": "https://app.clickup.com",
          "browse_url_template": "https://app.clickup.com/t/{ticket_id}",
          "prefixes": ["ACM"]
        },
        {
          "name": "Fizzy",
          "type": "fizzy",
          "base_url": "https://app.fizzy.do",
          "browse_url_template": "https://app.fizzy.do/{workspace_id}/cards/{ticket_id}",
          "workspace_id": "6180619",
          "prefixes": []
        }
      ],
      "links": [
        {"name": "Internal App", "url": "https://app.acme.com/", "type": "app"},
        {"name": "Documentation", "url": "https://docs.acme.com/", "type": "docs"},
        {"name": "GitHub Org", "url": "https://github.com/acme-corp", "type": "repo"},
        {"name": "Fizzy Board", "url": "https://app.fizzy.do/6180619/boards/main", "type": "app"}
      ],
      "log_prune": {
        "strategy": "trailing_window",
        "window_days": 90
      },
      "archive": {
        "after_days": 90,
        "year_key": "terminal_date",
        "strategy": "active_archived"
      },
      "status": "active"
    },
    "work-teamwork": {
      "name": "Initech (Teamwork)",
      "display_order": 1,
      "briefing_label": "Work — Initech",
      "task_dir": "_shared/domains/work-teamwork/tasks",
      "log_dir": "/path/to/org/logs",
      "data_dir": "/path/to/org/data",
      "id_prefix": "INT",
      "id_mode": "external",
      "default_owner": "user",
      "path_type": "mixed",
      "ticket_systems": [
        {
          "name": "Teamwork",
          "type": "teamwork",
          "base_url": "https://initech.teamwork.com",
          "browse_url_template": "https://initech.teamwork.com/app/tasks/{ticket_id}",
          "prefixes": ["INT"]
        },
        {
          "name": "Fizzy",
          "type": "fizzy",
          "base_url": "https://app.fizzy.do",
          "browse_url_template": "https://app.fizzy.do/{workspace_id}/cards/{ticket_id}",
          "workspace_id": "7291730",
          "prefixes": []
        }
      ],
      "links": [
        {"name": "TPS Reports", "url": "https://initech.com/tps/", "type": "app"},
        {"name": "Wiki", "url": "https://initech.teamwork.com/spaces", "type": "docs"},
        {"name": "Fizzy Board", "url": "https://app.fizzy.do/7291730/boards/main", "type": "app"}
      ],
      "log_prune": {
        "strategy": "trailing_window",
        "window_days": 90
      },
      "archive": {
        "after_days": 90,
        "year_key": "terminal_date",
        "strategy": "active_archived"
      },
      "status": "active"
    },
    "triv": {
      "name": "Three Rivers Duck Club",
      "display_order": 3,
      "briefing_label": "Triv \u2014 Three Rivers Duck Club",
      "task_dir": "_shared/domains/triv/tasks",
      "log_dir": "_shared/domains/triv/logs",
      "data_dir": "_shared/domains/triv/data",
      "id_prefix": "TRIV",
      "id_mode": "auto",
      "default_owner": "moo",
      "path_type": "relative",
      "ticket_systems": [],
      "links": [],
      "log_prune": {
        "strategy": "trailing_window",
        "window_days": 365
      },
      "archive": {
        "after_days": 365,
        "year_key": "terminal_date",
        "strategy": "active_archived"
      },
      "status": "active"
    }
  },
  "prune_strategy_definitions": {
    "trailing_window": "Find the most recent log file in the domain log tree. Delete files older than window_days before that file."
  },
  "archive_strategy_definitions": {
    "active_archived": "Non-terminal tasks in active/. Terminal tasks (done/cancelled/retired) older than after_days move to archived/{year}/ based on year_key."
  },
  "path_resolution": {
    "description": "relative paths resolve against $BASE_DIL. absolute paths used as-is. mixed means task_dir is relative but log_dir/data_dir may be absolute.",
    "base_var": "BASE_DIL",
    "default_base": "/home/moo/Documents/dil_agentic_memory_0001"
  }
}
