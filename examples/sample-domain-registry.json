  "domains": {
    "personal": {
      "name": "Personal",
      "display_order": 2,
      "briefing_label": "Personal",
      "task_dir": "_shared/domains/personal/tasks",
      "log_dir": "_shared/domains/personal/logs",
      "data_dir": "_shared/domains/personal/data",
      "id_prefix": "DIL",
      "id_mode": "auto",
      "default_owner": "moo",
      "path_type": "relative",
      "ticket_systems": [
        {
          "name": "Obsidian Vault",
          "type": "obsidian",
          "base_url": "obsidian://open?vault=dil_agentic_memory_0001",
          "browse_url_template": "obsidian://open?vault=dil_agentic_memory_0001&file=_shared%2Fdomains%2Fpersonal%2Ftasks%2Factive%2F{ticket_id}.md",
          "prefixes": ["DIL"],
          "url_templates": {
            "ticket": "{base_url}&file=_shared%2Fdomains%2Fpersonal%2Ftasks%2Factive%2F{ticket_id}.md"
          }
        }
      ],
      "links": [
        {"name": "DIL on GitHub", "url": "https://github.com/zigmoo/distributed_intent_ledger", "type": "repo"},
        {"name": "Fizzy", "url": "https://app.fizzy.do/", "type": "app"},
        {"name": "Getting Real (37signals)", "url": "https://basecamp.com/gettingreal", "type": "reference"},
        {"name": "Shape Up (37signals)", "url": "https://basecamp.com/shapeup", "type": "reference"},
        {"name": "1999.37signals.com", "url": "https://1999.37signals.com/", "type": "reference"}
      ],
      "log_prune": {
        "strategy": "trailing_window",
        "window_days": 180
      },
      "archive": {
        "after_days": 180,
        "year_key": "terminal_date",
        "strategy": "active_archived"
      },
      "status": "active"
    },
