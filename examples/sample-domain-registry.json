{
  "$schema": "dil-domain-registry-v1",
  "description": "Canonical domain registry for DIL operational path resolution",
  "updated": "2026-03-12",
  "domains": {
    "personal": {
      "name": "Personal",
      "display_order": 2,
      "briefing_label": "Personal",
